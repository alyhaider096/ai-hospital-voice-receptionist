# Application
APP_ENV=development
APP_NAME=AI Hospital Voice Receptionist
APP_BASE_URL=http://localhost:8000
FRONTEND_BASE_URL=http://localhost:3000
HOSPITAL_TIMEZONE=Asia/Karachi

# Database
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/hospital_voice_receptionist
POSTGRES_DB=hospital_voice_receptionist
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# Security
APP_SECRET_KEY=replace-with-random-secret
PII_ENCRYPTION_KEY=replace-with-fernet-key
VAPI_TOOL_SECRET=replace-with-long-random-vapi-secret
ADMIN_API_TOKEN=replace-with-long-random-admin-token

# Admin bootstrap
ADMIN_BOOTSTRAP_EMAIL=admin@example.com
ADMIN_BOOTSTRAP_PASSWORD=change-this-password

# Optional observability
SENTRY_DSN=
LOG_LEVEL=INFO
